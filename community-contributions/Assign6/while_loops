# Question 8: Count Positive, Negative, and Zero Values

positive = 0
negative = 0
zero = 0

while True:
    num = int(input("Enter an integer (999 to stop): "))

    if num == 999:
        break

    if num > 0:
        positive += 1
    elif num < 0:
        negative += 1
    else:
        zero += 1

print("Positive numbers:", positive)
print("Negative numbers:", negative)
print("Zeros:", zero)


# Question 9: Student Marks Analyzer

count = 0
total = 0
highest = None
lowest = None

while True:
    mark = int(input("Enter student mark (0-100) or -1 to stop: "))

    if mark == -1:
        break

    if 0 <= mark <= 100:
        count += 1
        total += mark

        if highest is None or mark > highest:
            highest = mark

        if lowest is None or mark < lowest:
            lowest = mark
    else:
        print("Invalid mark. Enter a value between 0 and 100.")

if count == 0:
    print("No marks were entered.")
else:
    average = total / count

    print("Total marks entered:", count)
    print("Average mark:", average)
    print("Highest mark:", highest)
    print("Lowest mark:", lowest)
    